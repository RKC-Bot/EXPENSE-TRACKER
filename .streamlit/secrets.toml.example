# Streamlit Cloud Secrets Configuration (Optional)
# 
# To use secrets:
# 1. Go to https://share.streamlit.io/ → your app → settings
# 2. Paste the contents of this file into the "Secrets" section
# 3. Replace placeholder values with actual data
# 4. Access in code with: st.secrets["key_name"]

# Database Configuration (if using cloud database)
# db_host = "your-db-host.rds.amazonaws.com"
# db_user = "admin"
# db_password = "your-secure-password"
# db_name = "expense_tracker"

# Google Sheets Integration (OAuth)
# google_client_id = "your-client-id.apps.googleusercontent.com"
# google_client_secret = "your-client-secret"

# API Keys
# openai_api_key = "sk-your-api-key"
# twilio_account_sid = "your-account-sid"

# Default Admin User (for first-time setup)
# default_admin_username = "admin"
# default_admin_password = "change_me_immediately"
